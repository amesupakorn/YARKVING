generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Track {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  imageCredit String? @map("image_credit")
  rating    Float
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
